// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id      Int      @id @default(autoincrement())
  username String
  email   String   @unique

}

model Event {
  id      Int      @id @default(autoincrement())
  name    String
  date    DateTime
  location String
  price Float
}

model Ticket {
  id         Int       @id @default(autoincrement())
  eventId    Int
  userId     Int
  quantity   Int
  price      Float 
  totalPrice Float
}

model Board {
  id String @id @default(uuid())

  title String
}