// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Define the User entity
model User {
  id               Int       @id @default(autoincrement())
  name             String?
  email            String    @unique
  // Add other user-related fields as needed, such as password, address, etc.
  events           Event[]   @relation("EventAttendees")
  createdEvents    Event[]   @relation("EventOrganizer")
  reviews          Review[]  // One-to-many relationship with reviews
}

// Define the Event entity
// Define the Event entity
model Event {
  id               Int       @id @default(autoincrement())
  name             String
  price            Int
  date             DateTime
  time             String
  location         String
  description      String
  availableSeats   Int
  isFree           Boolean
  ticketTypes      String?   // You may want to create a separate entity for ticket types if needed
  organizer        User      @relation(name: "EventOrganizer", fields: [organizerId], references: [id])
  organizerId      Int
  attendees        User[]    @relation(name: "EventAttendees")
  reviews          Review[]  // One-to-many relationship with reviews
  promotions       Promotion[]
  category         String?
  image            String?   // Tambahkan properti category
}


// Define the Review entity
model Review {
  id               Int       @id @default(autoincrement())
  overallRating    Int
  qualityRating    Int
  suggestions      String?
  event            Event     @relation(fields: [eventId], references: [id])
  eventId          Int
  reviewer         User      @relation(fields: [reviewerId], references: [id])
  reviewerId       Int
}

// Define the Promotion entity
model Promotion {
  id               Int       @id @default(autoincrement())
  discountAmount   Int
  availableSlots   Int
  referralCode     String
  event            Event     @relation(fields: [eventId], references: [id])
  eventId          Int
  // Add other fields related to promotions as needed
}
